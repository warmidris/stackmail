# Stackmail server
# Optional: if private key is omitted, one is auto-generated once and persisted in DB meta.
# Docker Compose data mount for DB + persisted signer key.
# Examples: ./data (host dir), /srv/stackmail-data (host dir), stackmail_data (named volume).
STACKMAIL_DATA_MOUNT=./data
# Optional signer principal override; must match STACKMAIL_SERVER_PRIVATE_KEY when set.
STACKMAIL_SERVER_STX_ADDRESS=
STACKMAIL_SERVER_PRIVATE_KEY=
STACKMAIL_SF_CONTRACT_ID=SP3QFYVTMS0PRJT3K3GMDW9DGR33TDHENSDWVNQMR.sm-stackflow
STACKMAIL_RESERVOIR_CONTRACT_ID=SP3QFYVTMS0PRJT3K3GMDW9DGR33TDHENSDWVNQMR.sm-reservoir
STACKMAIL_MESSAGE_PRICE_SATS=1000
STACKMAIL_MIN_FEE_SATS=100
STACKMAIL_MAX_PENDING_PER_SENDER=5
STACKMAIL_MAX_PENDING_PER_RECIPIENT=20
STACKMAIL_STACKS_NETWORK=mainnet

# Optional compatibility field for /status payload
STACKMAIL_STACKFLOW_NODE_URL=

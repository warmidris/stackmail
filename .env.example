# Mailslot server
# Optional: if private key is omitted, one is auto-generated once and persisted in DB meta.
# Docker Compose data mount for DB + persisted signer key.
# Examples: ./data (host dir), /srv/mailslot-data (host dir), mailslot_data (named volume).
MAILSLOT_DATA_MOUNT=./data
# Optional signer principal override; must match MAILSLOT_SERVER_PRIVATE_KEY when set.
MAILSLOT_SERVER_STX_ADDRESS=
MAILSLOT_SERVER_PRIVATE_KEY=
MAILSLOT_SF_CONTRACT_ID=SP3QFYVTMS0PRJT3K3GMDW9DGR33TDHENSDWVNQMR.sm-stackflow
MAILSLOT_RESERVOIR_CONTRACT_ID=SP3QFYVTMS0PRJT3K3GMDW9DGR33TDHENSDWVNQMR.sm-reservoir
MAILSLOT_MESSAGE_PRICE_SATS=100
MAILSLOT_MIN_FEE_SATS=10
MAILSLOT_MAX_PENDING_PER_SENDER=5
MAILSLOT_MAX_PENDING_PER_RECIPIENT=20
MAILSLOT_MAX_DEFERRED_PER_SENDER=5
MAILSLOT_MAX_DEFERRED_PER_RECIPIENT=20
MAILSLOT_MAX_DEFERRED_GLOBAL=200
MAILSLOT_DEFERRED_MESSAGE_TTL_MS=86400000
MAILSLOT_MAX_BORROW_PER_TAP=5000
MAILSLOT_RECEIVE_CAPACITY_MULTIPLIER=20
MAILSLOT_REFRESH_CAPACITY_COOLDOWN_MS=86400000
MAILSLOT_STACKS_NETWORK=mainnet
MAILSLOT_AUTH_AUDIENCE=https://mailslot.locker
MAILSLOT_ALLOWED_ORIGINS=https://mailslot.locker
MAILSLOT_RATE_LIMIT_WINDOW_MS=60000
MAILSLOT_RATE_LIMIT_MAX=120
MAILSLOT_RATE_LIMIT_AUTH_MAX=60
MAILSLOT_RATE_LIMIT_SEND_MAX=20
MAILSLOT_RATE_LIMIT_ADMIN_MAX=10
MAILSLOT_ENABLE_BROWSER_DECRYPT_KEY=false
MAILSLOT_DISPUTE_WEBHOOK_TOKEN=

# Optional compatibility field for /status payload
MAILSLOT_STACKFLOW_NODE_URL=
